{
  "name": "@logistics-ts/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo root for logistics-ts — a modular TypeScript supply-chain intelligence toolkit.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adam-drag/logistics-ts.git"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.7.1",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "deps:check": "depcruise packages --config .dependency-cruiser.cjs",
    "check": "pnpm lint && pnpm typecheck && pnpm build && pnpm test && pnpm deps:check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "example:quickstart": "tsx examples/quickstart.ts",
    "example:forecast-replenish": "tsx examples/forecast-and-replenish.ts",
    "example:inventory-analysis": "tsx examples/inventory-analysis.ts",
    "examples": "pnpm example:quickstart && pnpm example:forecast-replenish && pnpm example:inventory-analysis"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.9",
    "@types/node": "^26.1.1",
    "dependency-cruiser": "^16.4.2",
    "fast-check": "^4.9.0",
    "tsup": "^8",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1",
      "vite": "^6.4.3"
    }
  }
}
