{
  "name": "@logistics-ts/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo root for logistics-ts — a modular TypeScript supply-chain intelligence toolkit.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adam-drag/logistics-ts.git"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.7.1",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "deps:check": "depcruise packages --config .dependency-cruiser.cjs",
    "check": "pnpm lint && pnpm typecheck && pnpm build && pnpm test && pnpm deps:check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.9",
    "dependency-cruiser": "^16.4.2",
    "tsup": "^8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
