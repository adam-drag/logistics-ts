{
  "name": "@logistics-ts/inventory",
  "version": "0.0.1",
  "description": "Safety stock, reorder point, EOQ, coverage, and issue analysis for logistics-ts.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adam-drag/logistics-ts.git",
    "directory": "packages/inventory"
  },
  "homepage": "https://github.com/adam-drag/logistics-ts/tree/main/packages/inventory",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@logistics-ts/core": "workspace:*",
    "@logistics-ts/forecasting": "workspace:*"
  }
}
