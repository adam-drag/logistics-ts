{
  "name": "logistics-ts",
  "version": "0.1.0",
  "description": "Explainable supply-chain algorithms for TypeScript: safety stock, reorder point, EOQ, ABC/XYZ classification & demand forecasting (Croston/SBA/TSB) — dependency-light, built for humans and AI agents.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adam-drag/logistics-ts.git",
    "directory": "packages/logistics-ts"
  },
  "homepage": "https://github.com/adam-drag/logistics-ts",
  "keywords": [
    "supply-chain",
    "inventory",
    "forecasting",
    "safety-stock",
    "reorder-point",
    "eoq",
    "abc-xyz",
    "croston",
    "demand-planning",
    "mrp",
    "erp",
    "wms"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "skills"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@logistics-ts/classification": "workspace:*",
    "@logistics-ts/core": "workspace:*",
    "@logistics-ts/forecasting": "workspace:*",
    "@logistics-ts/inventory": "workspace:*"
  }
}
