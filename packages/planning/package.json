{
  "name": "@logistics-ts/planning",
  "version": "0.1.1",
  "description": "Lot-sizing, time-phased netting, and BOM explosion (MRP planning) for logistics-ts.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adam-drag/logistics-ts.git",
    "directory": "packages/planning"
  },
  "homepage": "https://github.com/adam-drag/logistics-ts/tree/main/packages/planning",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@logistics-ts/core": "workspace:*",
    "@logistics-ts/inventory": "workspace:*"
  }
}
